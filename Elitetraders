            <div style={{display:"flex",gap:"8px",marginBottom:"12px"}}>
              <button onClick={() => setStreak(s => s+1)} style={{flex:1,padding:"10px",borderRadius:"8px",background:"rgba(16,216,138,0.1)",border:"1px solid rgba(16,216,138,0.3)",color:"#10d88a",fontSize:"14px",fontWeight:"700",cursor:"pointer"}}>✅ WIN</button>
              <button onClick={() => { setStreak(s => s-1); setDailyLoss(d => d + Number(tradeSize)); }} style={{flex:1,padding:"10px",borderRadius:"8px",background:"rgba(255,77,109,0.1)",border:"1px solid rgba(255,77,109,0.3)",color:"#ff4d6d",fontSize:"14px",fontWeight:"700",cursor:"pointer"}}>❌ LOSS</button>
              <button onClick={() => { setStreak(0); setDailyLoss(0); }} style={{padding:"10px 16px",borderRadius:"8px",background:"#141926",border:"1px solid #252d40",color:"#8b93a8",fontSize:"13px",cursor:"pointer"}}>Reset</button>
            </div>
            <div style={{display:"flex",gap:"12px"}}>
              <div style={{flex:1,textAlign:"center"}}>
                <div style={{fontSize:"11px",color:"#8b93a8",marginBottom:"4px"}}>Streak</div>
                <div style={{fontSize:"24px",fontWeight:"800",fontFamily:"'JetBrains Mono',monospace",color: streak > 0 ? '#10d88a' : streak < 0 ? '#ff4d6d' : '#8b93a8'}}>{streak > 0 ? '+' : ''}{streak}</div>
              </div>
              <div style={{flex:1,textAlign:"center"}}>
                <div style={{fontSize:"11px",color:"#8b93a8",marginBottom:"4px"}}>Daily Loss</div>
                <div style={{fontSize:"24px",fontWeight:"800",fontFamily:"'JetBrains Mono',monospace",color: dailyLoss > Number(maxDailyLoss)*0.7 ? '#ff4d6d' : '#8b93a8'}}>${dailyLoss.toFixed(2)}</div>
              </div>
              <div style={{flex:1,textAlign:"center"}}>
                <div style={{fontSize:"11px",color:"#8b93a8",marginBottom:"4px"}}>Status</div>
                <div style={{fontSize:"14px",fontWeight:"700",color: dailyLoss >= Number(maxDailyLoss) ? '#ff4d6d' : '#10d88a'}}>
                  {dailyLoss >= Number(maxDailyLoss) ? '🛑 STOP!' : '🟢 OK'}
                </div>
              </div>
            </div>
            {dailyLoss >= Number(maxDailyLoss) && (
              <div style={{marginTop:"10px",padding:"10px 14px",borderRadius:"8px",background:"rgba(255,77,109,0.1)",border:"1px solid rgba(255,77,109,0.3)",color:"#ff4d6d",fontSize:"13px",fontWeight:"600",textAlign:"center"}}>
                🛑 Daily Loss Limit পৌঁছে গেছে! আজকের trade বন্ধ করুন।
              </div>
            )}
          </div>
        </div>
      )}

      {/* RULES TAB */}
      {activeTab === 'rules' && (
        <div style={{display:"flex",flexDirection:"column",gap:"12px"}}>
          {rules.map((r,i) => (
            <div key={i} style={{background:"#0f1420",border:`1px solid ${r.color}25`,borderLeft:`3px solid ${r.color}`,borderRadius:"12px",padding:"16px 18px",display:"flex",gap:"14px",alignItems:"flex-start"}}>
              <span style={{fontSize:"24px",flexShrink:0}}>{r.icon}</span>
              <div style={{flex:1}}>
                <div style={{display:"flex",alignItems:"center",gap:"8px",marginBottom:"6px"}}>
                  <span style={{fontSize:"14px",fontWeight:"700",color:r.color}}>{r.title}</span>
                  {r.recommended && <span style={{fontSize:"10px",padding:"2px 8px",borderRadius:"99px",background:"rgba(16,216,138,0.15)",color:"#10d88a",border:"1px solid rgba(16,216,138,0.3)"}}>✓ Recommended</span>}
                </div>
                <p style={{margin:"0",fontSize:"13px",color:"#8b93a8",lineHeight:"1.7"}}>{r.desc}</p>
              </div>
            </div>
          ))}

          {/* Golden Rules */}
          <div style={{background:"rgba(240,180,41,0.06)",border:"1px solid rgba(240,180,41,0.2)",borderRadius:"12px",padding:"18px"}}>
            <p style={{margin:"0 0 12px",fontSize:"14px",fontWeight:"700",color:"#f0b429"}}>⚡ Binary Trading-এর Golden Rules</p>
            {["কখনো ১ trade-এ ৫%-এর বেশি risk করো না","পরপর ২ loss হলে সেদিনের trade বন্ধ করো","Win করলেও overconfident হওয়া যাবে না","Profit তুলে নেওয়ার habit রাখো — account undo করো না","Strategy ছাড়া random trade = gambling"].map((rule, i) => (
              <div key={i} style={{display:"flex",gap:"10px",alignItems:"flex-start",padding:"8px 0",borderBottom: i<4 ? "1px solid rgba(240,180,41,0.1)" : "none"}}>
                <span style={{color:"#f0b429",fontWeight:"700",flexShrink:0}}>{i+1}.</span>
                <span style={{fontSize:"13px",color:"#b8bfcc"}}>{rule}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* MARTINGALE WARNING TAB */}
      {activeTab === 'martingale' && (
        <div>
          <div style={{padding:"16px 18px",borderRadius:"12px",background:"rgba(255,77,109,0.08)",border:"1px solid rgba(255,77,109,0.2)",marginBottom:"20px"}}>
            <p style={{margin:"0 0 6px",fontSize:"15px",fontWeight:"700",color:"#ff4d6d"}}>⚠️ Martingale Strategy সম্পর্কে সত্য কথা</p>
            <p style={{margin:"0",fontSize:"13px",color:"#b8bfcc",lineHeight:"1.8"}}>Martingale মানে loss হলে পরের trade-এ double করা। Short-term-এ কাজ করলেও দীর্ঘমেয়াদে account শেষ করে দেয়। নিচে দেখুন কীভাবে:</p>
          </div>

          <div style={{background:"#0f1420",border:"1px solid #252d40",borderRadius:"12px",padding:"18px",marginBottom:"16px"}}>
            <p style={{margin:"0 0 14px",fontSize:"13px",fontWeight:"600",color:"#8b93a8"}}>Balance: <span style={{color:"#f0b429"}}>${balance}</span> | Base trade: <span style={{color:"#f0b429"}}>${(balance * riskPct / 100).toFixed(2)}</span></p>
            <div style={{display:"flex",flexDirection:"column",gap:"8px"}}>
              {martingaleSteps.map((size, i) => {
                const lostSoFar = martingaleSteps.slice(0, i).reduce((a,b) => a + Number(b), 0).toFixed(2);
                const pct = ((Number(lostSoFar) / balance) * 100).toFixed(1);
                return (
                  <div key={i} style={{display:"flex",alignItems:"center",gap:"12px",padding:"10px 14px",borderRadius:"8px",background: i===0 ? "rgba(16,216,138,0.05)" : i < 3 ? "rgba(240,180,41,0.05)" : "rgba(255,77,109,0.08)",border:`1px solid ${i===0 ? "rgba(16,216,138,0.2)" : i<3 ? "rgba(240,180,41,0.2)" : "rgba(255,77,109,0.2)"}`}}>
                    <div style={{width:"28px",height:"28px",borderRadius:"50%",background: i<2 ? "rgba(240,180,41,0.15)" : "rgba(255,77,109,0.15)",display:"flex",alignItems:"center",justifyContent:"center",fontSize:"12px",fontWeight:"700",color: i<2 ? "#f0b429" : "#ff4d6d",flexShrink:0}}>L{i+1}</div>
                    <div style={{flex:1}}>
                      <div style={{fontSize:"13px",fontWeight:"600",color:"#e8eaf0",fontFamily:"'JetBrains Mono',monospace"}}>${size} <span style={{fontSize:"11px",color:"#8b93a8",fontFamily:"'Tiro Bangla',serif"}}>লাগাতে হবে</span></div>
                      <div style={{fontSize:"11px",color:"#8b93a8"}}>এখন পর্যন্ত হারিয়েছ: ${lostSoFar} ({pct}%)</div>
                    </div>
                    <div style={{fontSize:"11px",color: i<2 ? "#f0b429" : "#ff4d6d",fontWeight:"700"}}>{i===0?"×1":i===1?"×2.2":i===2?"×4.8":i===3?"×10.6":"×23.3"}</div>
                  </div>
                );
              })}
            </div>
            <div style={{marginTop:"14px",padding:"12px 14px",borderRadius:"8px",background:"rgba(255,77,109,0.1)",border:"1px solid rgba(255,77,109,0.3)",fontSize:"13px",color:"#ff4d6d",fontWeight:"600"}}>
              💀 ৫টা loss পরপর হলে balance-এর ~{((martingaleSteps.reduce((a,b)=>a+Number(b),0)/balance)*100).toFixed(0)}% চলে যাবে!
            </div>
          </div>

          <div style={{background:"rgba(16,216,138,0.06)",border:"1px solid rgba(16,216,138,0.2)",borderRadius:"12px",padding:"16px 18px"}}>
            <p style={{margin:"0 0 8px",fontSize:"13px",fontWeight:"700",color:"#10d88a"}}>✅ এর বদলে Fixed % System ব্যবহার করো:</p>
            <p style={{margin:"0",fontSize:"13px",color:"#8b93a8",lineHeight:"1.8"}}>প্রতি trade-এ একই % risk করো। Loss হলে trade size বাড়াবে না। এতে account survive করে এবং long-term-এ profit হয়।</p>
          </div>
        </div>
      )}
    </div>
  );
}

// ══════════════════════════════════════════════
// MOUNT FUNCTION
// ══════════════════════════════════════════════
function mountReactComponents() {
  const snrEl = document.getElementById('snr-root');
  if (snrEl) ReactDOM.createRoot(snrEl).render(React.createElement(SNRGuide));

  const paEl = document.getElementById('pa-root');
  if (paEl) ReactDOM.createRoot(paEl).render(React.createElement(PriceActionBook));

  const mmEl = document.getElementById('mm-root');
  if (mmEl) ReactDOM.createRoot(mmEl).render(React.createElement(MoneyManagement));
}

// Make mountReactComponents available globally
window.mountReactComponents = mountReactComponents;
</script>

</body>
</html>
