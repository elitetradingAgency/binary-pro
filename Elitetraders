<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Binary Pro — Trading Academy</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Tiro+Bangla:ital@0;1&family=JetBrains+Mono:wght@400;700&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
:root {
  --bg: #0a0d14;
  --bg2: #0f1420;
  --bg3: #141926;
  --card: #181f2e;
  --card2: #1e2639;
  --border: #252d40;
  --border2: #2e3850;
  --gold: #f0b429;
  --gold2: #e09b10;
  --green: #10d88a;
  --red: #ff4d6d;
  --blue: #4f9cf9;
  --purple: #a78bfa;
  --text: #e8eaf0;
  --text2: #8b93a8;
  --text3: #5a6278;
  --accent: #f0b429;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { background: var(--bg); color: var(--text); font-family: 'Sora', sans-serif; min-height: 100vh; overflow-x: hidden; }
.bangla { font-family: 'Tiro Bangla', serif; }
.mono { font-family: 'JetBrains Mono', monospace; }

/* Scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 4px; }

/* Login Screen */
#login-screen {
  position: fixed; inset: 0; background: var(--bg);
  display: flex; align-items: center; justify-content: center;
  z-index: 1000;
  background-image: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(240,180,41,0.08) 0%, transparent 60%);
}
.login-box {
  width: 100%; max-width: 420px; padding: 48px 40px;
  background: var(--card); border: 1px solid var(--border2);
  border-radius: 20px; text-align: center;
  box-shadow: 0 0 80px rgba(240,180,41,0.06), 0 40px 60px rgba(0,0,0,0.6);
}
.login-logo {
  width: 64px; height: 64px; background: linear-gradient(135deg, var(--gold), #d97706);
  border-radius: 16px; display: flex; align-items: center; justify-content: center;
  font-size: 28px; margin: 0 auto 20px; box-shadow: 0 8px 24px rgba(240,180,41,0.3);
}
.login-title { font-size: 22px; font-weight: 800; color: var(--text); margin-bottom: 6px; }
.login-sub { font-size: 13px; color: var(--text2); margin-bottom: 32px; line-height: 1.6; font-family: 'Tiro Bangla', serif; }
.login-input-wrap { position: relative; margin-bottom: 16px; }
.login-input {
  width: 100%; padding: 14px 20px; background: var(--bg2);
  border: 1.5px solid var(--border2); border-radius: 12px;
  color: var(--text); font-size: 18px; letter-spacing: 6px;
  text-align: center; font-family: 'JetBrains Mono', monospace;
  outline: none; transition: border-color 0.2s;
}
.login-input:focus { border-color: var(--gold); }
.login-input::placeholder { letter-spacing: 2px; font-size: 13px; color: var(--text3); }
.login-btn {
  width: 100%; padding: 14px; background: linear-gradient(135deg, var(--gold), #d97706);
  border: none; border-radius: 12px; color: #0a0d14; font-size: 15px; font-weight: 700;
  cursor: pointer; transition: opacity 0.2s; font-family: 'Sora', sans-serif;
}
.login-btn:hover { opacity: 0.9; }
.login-error { color: var(--red); font-size: 13px; margin-top: 12px; font-family: 'Tiro Bangla', serif; }
.login-hint { font-size: 12px; color: var(--text3); margin-top: 24px; font-family: 'Tiro Bangla', serif; line-height: 1.7; }
.login-month-badge {
  display: inline-block; padding: 4px 12px; background: rgba(240,180,41,0.1);
  border: 1px solid rgba(240,180,41,0.3); border-radius: 99px;
  color: var(--gold); font-size: 12px; font-family: 'JetBrains Mono', monospace;
  margin-bottom: 20px;
}

/* Main App */
#app { display: none; min-height: 100vh; }

/* Sidebar */
.sidebar {
  position: fixed; left: 0; top: 0; bottom: 0; width: 240px;
  background: var(--bg2); border-right: 1px solid var(--border);
  display: flex; flex-direction: column; z-index: 100;
  transition: transform 0.3s;
}
.sidebar-logo {
  padding: 24px 20px 20px;
  border-bottom: 1px solid var(--border);
}
.logo-mark {
  display: flex; align-items: center; gap: 10px;
}
.logo-icon {
  width: 36px; height: 36px; background: linear-gradient(135deg, var(--gold), #d97706);
  border-radius: 10px; display: flex; align-items: center; justify-content: center;
  font-size: 16px; flex-shrink: 0;
}
.logo-text { font-size: 16px; font-weight: 800; color: var(--text); }
.logo-sub { font-size: 10px; color: var(--text3); font-family: 'Tiro Bangla', serif; margin-top: 1px; }
.sidebar-nav { flex: 1; padding: 16px 12px; overflow-y: auto; }
.nav-section-label {
  font-size: 9px; font-weight: 700; color: var(--text3); letter-spacing: 0.1em;
  text-transform: uppercase; padding: 0 8px; margin: 16px 0 6px;
}
.nav-item {
  display: flex; align-items: center; gap: 10px; padding: 10px 12px;
  border-radius: 10px; cursor: pointer; transition: all 0.15s;
  color: var(--text2); font-size: 13px; font-weight: 500;
  font-family: 'Tiro Bangla', serif; margin-bottom: 2px;
  border: 1px solid transparent;
}
.nav-item:hover { background: var(--bg3); color: var(--text); }
.nav-item.active {
  background: rgba(240,180,41,0.1); color: var(--gold);
  border-color: rgba(240,180,41,0.2);
}
.nav-item .nav-icon { font-size: 16px; flex-shrink: 0; }
.sidebar-footer {
  padding: 16px; border-top: 1px solid var(--border);
}
.current-code-box {
  background: var(--bg3); border: 1px solid var(--border2);
  border-radius: 10px; padding: 10px 12px;
}
.code-label { font-size: 10px; color: var(--text3); font-family: 'Tiro Bangla', serif; margin-bottom: 4px; }
.code-value { font-size: 14px; font-weight: 700; color: var(--gold); font-family: 'JetBrains Mono', monospace; letter-spacing: 3px; }
.code-month { font-size: 10px; color: var(--text3); font-family: 'JetBrains Mono', monospace; margin-top: 2px; }

/* Main Content */
.main-content {
  margin-left: 240px; min-height: 100vh;
  background-image: radial-gradient(ellipse 60% 40% at 80% 0%, rgba(240,180,41,0.04) 0%, transparent 50%);
}
.page { display: none; padding: 32px; max-width: 960px; }
.page.active { display: block; }

/* Page Header */
.page-header { margin-bottom: 28px; }
.page-label { font-size: 11px; color: var(--text3); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px; font-family: 'JetBrains Mono', monospace; }
.page-title { font-size: 28px; font-weight: 800; color: var(--text); line-height: 1.2; font-family: 'Tiro Bangla', serif; }
.page-title span { color: var(--gold); }
.page-desc { font-size: 14px; color: var(--text2); margin-top: 8px; line-height: 1.7; font-family: 'Tiro Bangla', serif; }

/* Dashboard Cards */
.dashboard-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 24px; }
.stat-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 14px; padding: 20px 22px;
  position: relative; overflow: hidden;
}
.stat-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
}
.stat-card.gold::before { background: linear-gradient(90deg, var(--gold), transparent); }
.stat-card.green::before { background: linear-gradient(90deg, var(--green), transparent); }
.stat-card.blue::before { background: linear-gradient(90deg, var(--blue), transparent); }
.stat-card.red::before { background: linear-gradient(90deg, var(--red), transparent); }
.stat-icon { font-size: 24px; margin-bottom: 10px; }
.stat-num { font-size: 32px; font-weight: 800; font-family: 'JetBrains Mono', monospace; }
.stat-num.gold { color: var(--gold); }
.stat-num.green { color: var(--green); }
.stat-num.blue { color: var(--blue); }
.stat-num.red { color: var(--red); }
.stat-label { font-size: 12px; color: var(--text2); margin-top: 4px; font-family: 'Tiro Bangla', serif; }

.section-cards { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
.section-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 14px; padding: 20px;
  cursor: pointer; transition: all 0.2s;
  position: relative; overflow: hidden;
}
.section-card:hover { border-color: var(--border2); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.3); }
.section-card-icon { font-size: 28px; margin-bottom: 12px; }
.section-card-title { font-size: 15px; font-weight: 700; color: var(--text); font-family: 'Tiro Bangla', serif; margin-bottom: 4px; }
.section-card-desc { font-size: 12px; color: var(--text2); font-family: 'Tiro Bangla', serif; line-height: 1.6; }
.section-card-badge {
  position: absolute; top: 14px; right: 14px;
  font-size: 10px; padding: 2px 8px; border-radius: 99px;
  font-family: 'JetBrains Mono', monospace; font-weight: 700;
}
.badge-gold { background: rgba(240,180,41,0.15); color: var(--gold); border: 1px solid rgba(240,180,41,0.3); }
.badge-green { background: rgba(16,216,138,0.15); color: var(--green); border: 1px solid rgba(16,216,138,0.3); }

/* Content Wrapper for JSX components */
.content-wrapper {
  background: var(--card); border: 1px solid var(--border);
  border-radius: 16px; padding: 24px;
}

/* Telegram Banner */
.tg-banner {
  background: linear-gradient(135deg, rgba(79,156,249,0.1), rgba(79,156,249,0.05));
  border: 1px solid rgba(79,156,249,0.2); border-radius: 14px;
  padding: 20px 24px; display: flex; align-items: center; gap: 16px; margin-bottom: 24px;
}
.tg-icon { font-size: 32px; flex-shrink: 0; }
.tg-text h3 { font-size: 14px; font-weight: 700; color: var(--blue); font-family: 'Tiro Bangla', serif; margin-bottom: 3px; }
.tg-text p { font-size: 12px; color: var(--text2); font-family: 'Tiro Bangla', serif; line-height: 1.6; }
.tg-btn {
  margin-left: auto; padding: 8px 18px; background: var(--blue);
  border: none; border-radius: 8px; color: white; font-size: 12px;
  font-weight: 700; cursor: pointer; white-space: nowrap; flex-shrink: 0;
  font-family: 'Tiro Bangla', serif;
}

/* Mobile Toggle */
.mobile-toggle {
  display: none; position: fixed; top: 16px; right: 16px; z-index: 200;
  width: 40px; height: 40px; background: var(--card);
  border: 1px solid var(--border2); border-radius: 10px;
  align-items: center; justify-content: center; cursor: pointer;
  font-size: 18px;
}
.sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 99; }

@media (max-width: 768px) {
  .sidebar { transform: translateX(-100%); }
  .sidebar.open { transform: translateX(0); }
  .main-content { margin-left: 0; }
  .mobile-toggle { display: flex; }
  .sidebar-overlay.open { display: block; }
  .page { padding: 20px 16px; }
  .dashboard-grid, .section-cards { grid-template-columns: 1fr; }
}

/* Override inner component styles to work in dark theme */
.content-wrapper [style*="background:white"],
.content-wrapper [style*='background:"white"'] { }

/* Tabs for inner components */
.inner-tabs {
  display: flex; gap: 6px; margin-bottom: 20px;
  border-bottom: 1px solid var(--border); padding-bottom: 12px; flex-wrap: wrap;
}
.inner-tab {
  padding: 6px 14px; border-radius: 8px; cursor: pointer;
  font-size: 12px; font-weight: 600; border: 1px solid var(--border2);
  background: var(--bg3); color: var(--text2); transition: all 0.15s;
  font-family: 'Tiro Bangla', serif;
}
.inner-tab.active { background: rgba(240,180,41,0.1); color: var(--gold); border-color: rgba(240,180,41,0.3); }
</style>
</head>
<body>

<!-- LOGIN SCREEN -->
