        <button onClick={() => setActive(Math.max(0,active-1))} disabled={active===0} style={{padding:"8px 18px",borderRadius:"8px",border:"1px solid #252d40",background:"#141926",fontSize:"13px",cursor:active===0?"not-allowed":"pointer",color:active===0?"#3d4558":"#e8eaf0"}}>← আগে</button>
        <div style={{display:"flex",gap:"4px"}}>
          {paChapters.map((_,i) => (
            <div key={i} onClick={() => setActive(i)} style={{width:i===active?16:6,height:6,borderRadius:3,background:i===active ? ch.color : "#252d40",cursor:"pointer",transition:"all 0.2s"}}/>
