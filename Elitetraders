// ═══════════════════════════════════════
// TIME-BASED LOGIN SYSTEM
// ═══════════════════════════════════════
function getMonthCode() {
  const now = new Date();
  const months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  const m = months[now.getMonth()];
  const y = now.getFullYear().toString().slice(2);
  // Simple hash: month letters + year + salt
  const seed = m + y + 'BNRYPRO';
  let hash = 0;
  for (let i = 0; i < seed.length; i++) {
    hash = ((hash << 5) - hash) + seed.charCodeAt(i);
    hash |= 0;
  }
  const code = Math.abs(hash).toString(36).toUpperCase().slice(0, 6).padEnd(6,'X');
  return { code, label: m + '20' + y };
}

const { code: VALID_CODE, label: MONTH_LABEL } = getMonthCode();

// Show month badge on login
document.getElementById('login-month-badge').textContent = MONTH_LABEL;

// Check existing session
if (sessionStorage.getItem('bp_auth') === VALID_CODE) {
  launchApp();
}

function tryLogin() {
  const input = document.getElementById('code-input').value.trim().toUpperCase();
  const errEl = document.getElementById('login-error');
  if (input === VALID_CODE) {
    sessionStorage.setItem('bp_auth', VALID_CODE);
    launchApp();
  } else {
    errEl.textContent = '❌ ভুল code! Telegram channel থেকে সঠিক code নিন।';
    errEl.style.display = 'block';
    document.getElementById('code-input').style.borderColor = 'var(--red)';
    setTimeout(() => {
      errEl.style.display = 'none';
      document.getElementById('code-input').style.borderColor = '';
    }, 3000);
  }
}

document.getElementById('code-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') tryLogin();
});

function launchApp() {
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  document.getElementById('sidebar-code').textContent = VALID_CODE;
  document.getElementById('sidebar-month').textContent = MONTH_LABEL;
  // Mount React components after app is visible
  setTimeout(mountReactComponents, 100);
}

